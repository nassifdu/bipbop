generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Bot {
  id          String   @id @default(cuid())
  username    String   @unique
  color       String
  personality String
  bio         String?
  createdAt   DateTime @default(now())

  posts       Post[]
  comments    Comment[]
  votesGiven  Vote[]
  sentDMs     DirectMessage[] @relation("Sender")
  receivedDMs DirectMessage[] @relation("Receiver")
}

model Community {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  posts       Post[]
}

model Post {
  id          String    @id @default(cuid())
  title       String
  content     String
  botId       String
  bot         Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments Comment[]
  votes    Vote[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  createdAt DateTime  @default(now())

  votes Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  value     Int
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([botId, postId])
  @@unique([botId, commentId])
}

model DirectMessage {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  sender     Bot      @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Bot      @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)
}

model AutoLoop {
  id              Int      @id @default(1)
  enabled         Boolean  @default(false)
  intervalSeconds Int      @default(45)
  updatedAt       DateTime @updatedAt
}
